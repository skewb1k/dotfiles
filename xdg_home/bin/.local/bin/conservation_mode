#!/bin/bash

FILE="/sys/bus/platform/drivers/ideapad_acpi/VPC2004:00/conservation_mode"

# Check if file exists
if [[ ! -f "$FILE" ]]; then
    echo "Conservation mode control file not found: $FILE" >&2
    exit 1
fi

case "$1" in
    get)
        cat "$FILE"
        ;;
    set)
        if [[ "$EUID" -ne 0 ]]; then
            exec sudo "$0" "$@"
        fi

        if [[ "$2" != "0" && "$2" != "1" ]]; then
            echo "Usage: $0 set [0|1]" >&2
            exit 1
        fi

        echo "$2" > "$FILE"
        echo "Conservation mode set to $2."
        ;;
    *)
        echo "Usage: $0 [get | set 0|1]" >&2
        exit 1
        ;;
esac

